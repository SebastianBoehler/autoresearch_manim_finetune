{
  "name": "m4-max-qwen25coder-3b-baseline",
  "base_model": "Qwen/Qwen2.5-Coder-3B-Instruct",
  "source_dataset": "data/manim_bootstrap_cases.jsonl",
  "dataset_dir": "artifacts/datasets/m4-max-qwen25coder-3b",
  "adapter_path": "artifacts/adapters/m4-max-qwen25coder-3b",
  "eval_output_path": "artifacts/evals/m4-max-qwen25coder-3b.json",
  "results_tsv": "results.tsv",
  "run_loss_eval": true,
  "splits": {
    "train_fraction": 0.75,
    "valid_fraction": 0.125,
    "seed": 42
  },
  "train": {
    "fine_tune_type": "lora",
    "optimizer": "adamw",
    "mask_prompt": true,
    "num_layers": 12,
    "batch_size": 1,
    "iters": 300,
    "val_batches": 25,
    "learning_rate": 0.0001,
    "steps_per_report": 10,
    "steps_per_eval": 25,
    "grad_accumulation_steps": 8,
    "save_every": 100,
    "test_batches": -1,
    "max_seq_length": 2048,
    "grad_checkpoint": true,
    "seed": 42
  },
  "generation": {
    "max_tokens": 1024,
    "temperature": 0.2,
    "top_p": 0.95,
    "top_k": 40,
    "seed": 42
  },
  "evaluation": {
    "run_render": true,
    "max_cases": 0,
    "render_quality": "low",
    "max_render_seconds": 120,
    "allowed_render_regression": 0.05,
    "min_loss_delta": 0.01,
    "tie_loss_delta": 0.003,
    "metric_weights": {
      "syntax": 0.25,
      "scene_class": 0.15,
      "required_snippets": 0.25,
      "forbidden_snippets": 0.05,
      "render": 0.3
    }
  }
}

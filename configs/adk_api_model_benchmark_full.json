{
  "name": "adk-api-model-benchmark",
  "dataset_dir": "artifacts/datasets/m4-max-qwen25coder-3b",
  "output_dir": "artifacts/benchmarks/adk-api-model-benchmark",
  "generation": {
    "max_tokens": 2560,
    "temperature": 0.2,
    "top_p": 0.95,
    "top_k": 40,
    "seed": 42
  },
  "evaluation": {
    "run_render": true,
    "max_cases": 0,
    "render_quality": "low",
    "max_render_seconds": 120,
    "allowed_render_regression": 0.05,
    "min_loss_delta": 0.01,
    "tie_loss_delta": 0.003,
    "metric_weights": {
      "syntax": 0.25,
      "scene_class": 0.15,
      "required_snippets": 0.25,
      "forbidden_snippets": 0.05,
      "render": 0.3
    }
  },
  "targets": [
    {
      "name": "qwen-qwen3-6-plus-free-adk",
      "backend": "adk_openrouter",
      "model": "qwen/qwen3.6-plus:free"
    },
    {
      "name": "minimax-m2-7-adk",
      "backend": "adk_openrouter",
      "model": "minimax/minimax-m2.7"
    },
    {
      "name": "nvidia-nemotron-3-super-120b-a12b-free-adk",
      "backend": "adk_openrouter",
      "model": "nvidia/nemotron-3-super-120b-a12b:free"
    }
  ]
}

{
  "name": "m4-max-qwen25coder-3b-release-render",
  "base_model": "Qwen/Qwen2.5-Coder-3B-Instruct",
  "source_dataset": "data/manim_dataset.jsonl",
  "dataset_dir": "artifacts/datasets/m4-max-qwen25coder-3b-gold-silver",
  "adapter_path": "artifacts/weco/manim-render-reliability-trial-2c7ba720a4a1/adapter",
  "eval_output_path": "artifacts/evals/m4-max-qwen25coder-3b-gold-silver-weco-2c7-repair-full.json",
  "results_tsv": "results.tsv",
  "run_loss_eval": true,
  "dataset_filter": {
    "include_tags": [],
    "exclude_tags": []
  },
  "splits": {
    "train_fraction": 0.75,
    "valid_fraction": 0.125,
    "seed": 42
  },
  "train": {
    "fine_tune_type": "lora",
    "optimizer": "adamw",
    "mask_prompt": true,
    "num_layers": 12,
    "batch_size": 1,
    "iters": 100,
    "val_batches": 12,
    "learning_rate": 0.00008,
    "steps_per_report": 10,
    "steps_per_eval": 20,
    "grad_accumulation_steps": 8,
    "save_every": 20,
    "test_batches": -1,
    "max_seq_length": 3072,
    "grad_checkpoint": true,
    "seed": 42,
    "early_stopping_patience": 2,
    "early_stopping_min_delta": 0.003,
    "early_stopping_chunk_size": 20,
    "restore_best_checkpoint": true
  },
  "generation": {
    "max_tokens": 1600,
    "temperature": 0.0,
    "top_p": 0.9,
    "top_k": 0,
    "seed": 42
  },
  "evaluation": {
    "run_render": true,
    "max_cases": 0,
    "render_quality": "low",
    "max_render_seconds": 120,
    "allowed_render_regression": 0.05,
    "min_loss_delta": 0.01,
    "tie_loss_delta": 0.003,
    "metric_weights": {
      "syntax": 0.25,
      "scene_class": 0.15,
      "required_snippets": 0.25,
      "forbidden_snippets": 0.05,
      "render": 0.3
